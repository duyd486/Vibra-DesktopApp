<UserControl x:Class="Vibra_DesktopApp.Views.Components.Player"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Vibra_DesktopApp.Views.Components"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="76" d:DesignWidth="1600">
    
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>      
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= LEFT: SONG INFO ================= -->
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="20 0 0 0">

            <!-- Thumbnail -->
            <Border Width="52"
                    Height="52"
                    CornerRadius="26"
                    ClipToBounds="True">
                <Grid Width="52" Height="52">
                    <Image Source="/Assets/Images/default.jpg" Stretch="UniformToFill" Width="52" Height="52"/>
                    <Image Source="{Binding SongManager.CurrentTrack.thumbnail_path}" Stretch="UniformToFill" Width="52" Height="52"/>
                </Grid>
            </Border>

            <!-- Song title + artist (left) + actions (right), vertically centered with thumbnail -->
            <Grid Margin="16 0 0 0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title + Artist -->
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding SongManager.CurrentTrack.name}"
                               Foreground="{DynamicResource AppTextBrush}"
                               FontWeight="SemiBold"
                               FontSize="14"
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock Text="{Binding SongManager.CurrentTrack.author.name}"
                               Foreground="#AAAAAA"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Actions (placeholders: plus + download will be wired later) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Background="Transparent"
                            BorderThickness="0"
                            Padding="6"
                            Command="{Binding ToggleLoveCommand}">
                        <fa:IconBlock FontSize="16" Foreground="{DynamicResource BrightCurrentColor}">
                            <fa:IconBlock.Style>
                                <Style TargetType="fa:IconBlock">
                                    <Setter Property="Icon" Value="HeartCircleCheck"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrentTrackLoved}" Value="False">
                                            <Setter Property="Icon" Value="Heart"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </fa:IconBlock.Style>
                        </fa:IconBlock>
                    </Button>

                    <!-- Add to playlist Button -->
                    <Grid>
                        <Button x:Name="AddToPlaylistToggle"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="6"
                                Command="{Binding ToggleAddToPlaylistMenuCommand}">
                            <fa:IconBlock Icon="PlusCircle" FontSize="16" Foreground="{DynamicResource BrightCurrentColor}" />
                        </Button>

                        <Popup PlacementTarget="{Binding ElementName=AddToPlaylistToggle}"
                               Placement="Top"
                               StaysOpen="False"
                               IsOpen="{Binding IsAddToPlaylistMenuOpen, Mode=TwoWay}"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Background="#111"
                                    CornerRadius="8"
                                    Padding="8"
                                    BorderBrush="#333"
                                    BorderThickness="1">
                                <StackPanel MinWidth="260">
                                    <TextBlock Text="Thêm vào playlist"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               FontWeight="SemiBold"
                                               Margin="6,2,6,6" />

                                    <TextBlock Text="Chưa có playlist"
                                               Foreground="#AAAAAA"
                                               Margin="6,4"
                                               Visibility="{Binding AvailablePlaylistsForCurrentTrack.Count, Converter={StaticResource ZeroToVisibilityConverter}}" />

                                    <ItemsControl ItemsSource="{Binding AvailablePlaylistsForCurrentTrack}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Background="Transparent"
                                                        BorderThickness="0"
                                                        HorizontalContentAlignment="Stretch"
                                                        Padding="0"
                                                        Command="{Binding DataContext.AddCurrentTrackToPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Border CornerRadius="6" Padding="4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#222" />
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{Binding name}"
                                                                       Foreground="{DynamicResource AppTextBrush}"
                                                                       FontSize="12"
                                                                       Margin="8,6" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="Thêm vào danh sách phát"
                                                                       Foreground="#AAAAAA"
                                                                       FontSize="10"
                                                                       Margin="8,6" />
                                                        </Grid>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <Button Background="Transparent"
                            BorderThickness="0"
                            Padding="6">
                        <fa:IconBlock Icon="Download" FontSize="16" Foreground="{DynamicResource BrightCurrentColor}" />
                    </Button>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- ================= CENTER: CONTROLS ================= -->
        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <!-- Control buttons -->
            
            
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Background="Transparent"
                        BorderThickness="0"
                        Margin="8,0"
                        Command="{Binding ToggleShuffleCommand}">
                    <fa:IconBlock FontSize="16"
                                  Foreground="{DynamicResource AppTextBrush}"
                                  Icon="Random"
                                  Opacity="{Binding IsShuffle, Converter={StaticResource BoolToShuffleOpacityConverter}}" />
                </Button>

                <Button Background="Transparent"
                        BorderThickness="0"
                        Margin="8,0"
                        Command="{Binding PrevCommand}">
                    <fa:IconBlock Icon="StepBackward"
                                  Foreground="{DynamicResource AppTextBrush}"
                                  FontSize="18" />
                </Button>

                <!-- Play button -->

                <Button Width="40"
                        Height="40"
                        Background="{DynamicResource AppTextBrush}"
                        Margin="20 0 20 4"
                        Style="{StaticResource IconButtonStyle}"
                        Command="{Binding PlayOrPauseCommand}"
                        >

                    <fa:IconBlock Icon="{Binding SongManager.IsPlaying, Converter={StaticResource BoolToIconConverter}}"
                                  Foreground="{DynamicResource ControlBackgroundBrush}"
                                  FontSize="18"
                                  Margin="2 0 0 0"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                </Button>

                <Button Background="Transparent"
                        BorderThickness="0"
                        Margin="8,0"
                        Command="{Binding NextCommand}">
                    <fa:IconBlock Icon="StepForward"
                                  Foreground="{DynamicResource AppTextBrush}"
                                  FontSize="18" />
                </Button>

                <fa:IconBlock Icon="RedoAlt"
                              Foreground="{DynamicResource AppTextBrush}"
                              FontSize="16"
                              Margin="12,0"/>
            </StackPanel>

            <!-- Progress bar -->
            <Grid Width="420"
                  VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding SongManager.CurrentTime, Converter={StaticResource TimeConverter}}"
                           Foreground="{DynamicResource AppTextBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>

                <Slider Grid.Column="1"
                        Minimum="0"
                        Maximum="{Binding SongManager.Duration}"
                        Value="{Binding SliderValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Margin="8,0"
                        Height="20"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource AppTextBrush}"
                        Background="{DynamicResource AppTextBrush}">
                    <!-- Use behaviors to pause on drag start and seek+resume on drag complete.
                         Requires Microsoft.Xaml.Behaviors.Wpf package. -->
                    <i:Interaction.Triggers>
                        <!-- Use pointer-down to detect start of user drag (Slider doesn't expose DragStarted to behaviors reliably) -->
                        <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                            <i:InvokeCommandAction Command="{Binding SeekStartedCommand}" />
                        </i:EventTrigger>

                        <i:EventTrigger EventName="PreviewTouchDown">
                            <i:InvokeCommandAction Command="{Binding SeekStartedCommand}" />
                        </i:EventTrigger>

                        <i:EventTrigger EventName="DragCompleted">
                            <i:InvokeCommandAction Command="{Binding SeekCompletedCommand}"
                                   CommandParameter="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=Slider}}"/>
                        </i:EventTrigger>

                        <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                            <i:InvokeCommandAction Command="{Binding SeekCompletedCommand}"
                                   CommandParameter="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=Slider}}"/>
                        </i:EventTrigger>

                        <i:EventTrigger EventName="PreviewTouchUp">
                            <i:InvokeCommandAction Command="{Binding SeekCompletedCommand}"
                                   CommandParameter="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=Slider}}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>

                    <Slider.Template>
                        <ControlTemplate TargetType="Slider">
                            <Grid VerticalAlignment="Center">
                                <Track x:Name="PART_Track" Height="10">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton IsHitTestVisible="False"
                                                      Height="4"
                                                      Background="{DynamicResource BrightCurrentColor}"
                                                      BorderThickness="0">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>

                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton IsHitTestVisible="False"
                                                      Height="4"
                                                      Background="{DynamicResource DarkCurrentColor}"
                                                      BorderThickness="0">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>

                                    <Track.Thumb>
                                        <Thumb Width="10"
                                               Height="10"
                                               Background="{DynamicResource CurrentColor}"
                                               VerticalAlignment="Center">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Ellipse Fill="{TemplateBinding Background}"/>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>

                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Slider.Template>
                </Slider>

                <TextBlock Grid.Column="2"
                           Text="{Binding SongManager.Duration, Converter={StaticResource TimeConverter}}"
                           Foreground="{DynamicResource AppTextBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <!-- ================= RIGHT: ACTIONS + VOLUME ================= -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right">

            <Button Background="Transparent"
                    BorderThickness="0" Margin="10 0">
                <fa:IconBlock Icon="VolumeUp"
                              Foreground="{DynamicResource CurrentColor}"
                              FontSize="16"
                              Margin="4 0"/>
            </Button>

            <!-- Volume slider -->
            <Slider Width="90"
                    Height="10"
                    VerticalAlignment="Center"
                    Margin="0 0 16 0"
                    Background="Gray"
                    Minimum="0"
                    Maximum="1"
                    Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <Slider.Template>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Track x:Name="PART_Track" Height="10">

                                <!-- PHẦN ĐÃ CHẠY -->
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton IsHitTestVisible="False"
                                  Height="4"
                                  Background="{DynamicResource CurrentColor}"
                                  BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>

                                <!-- PHẦN CHƯA CHẠY -->
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton IsHitTestVisible="False"
                                  Height="4"
                                  Background="Gray"
                                  BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>

                                <!-- THUMB -->
                                <Track.Thumb>
                                    <Thumb Width="10"
                           Height="10"
                           Background="{DynamicResource CurrentColor}"
                           VerticalAlignment="Center">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{TemplateBinding Background}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>

                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Slider.Template>
            </Slider>

            <Button Background="Transparent"
                    BorderThickness="0" Margin="10 0"
                    Command="{Binding TogglePanelCommand}">
                <fa:IconBlock Icon="List"
                              Foreground="{DynamicResource AppTextBrush}"
                              FontSize="16"
                              Margin="4 0"/>
            </Button>

            <Button Background="Transparent"
                    BorderThickness="0" Margin="10 0"
                    Command="{Binding TogglePanelCommand}">
                <fa:IconBlock Icon="TabletScreenButton"
                              Foreground="{DynamicResource AppTextBrush}"
                              FontSize="16"
                              Margin="4 0"/>
            </Button>

            <Button Background="Transparent"
                    BorderThickness="0" Margin="10 0 20 0">
                <fa:IconBlock Icon="Expand"
                              Foreground="{DynamicResource AppTextBrush}"
                              FontSize="24"
                              Margin="4 0"/>
            </Button>
        </StackPanel>

    </Grid>
</UserControl>
