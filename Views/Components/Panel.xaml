<UserControl x:Class="Vibra_DesktopApp.Views.Components.Panel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Vibra_DesktopApp.Views.Components"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="200">
    <Grid>
        <!-- ================= QUEUE (WAITLIST) - kept intact ================= -->
        <Border CornerRadius="0"
                Background="{DynamicResource WindowBackgroundBrush}"
                Margin="0 5 5 5"
                Visibility="{Binding IsQueueContent, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Bài hát đang phát"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppTextBrush}"/>

                <Button Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10"
                        HorizontalContentAlignment="Stretch"
                        Command="{Binding PlayOrPauseCurrentCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="48" Height="48" CornerRadius="24" ClipToBounds="True">
                            <Grid Width="48" Height="48">
                                <Image Source="/Assets/Images/default.jpg" Stretch="UniformToFill" Width="48" Height="48"/>
                                <Image Source="{Binding SongManager.CurrentTrack.thumbnail_path}" Stretch="UniformToFill" Width="48" Height="48"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SongManager.CurrentTrack.name}"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding SongManager.CurrentTrack.author.name}"
                                       Foreground="{DynamicResource AppTextMutedBrush}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <fa:IconBlock Grid.Column="2"
                                      Icon="{Binding SongManager.IsPlaying, Converter={StaticResource BoolToIconConverter}}"
                                      Foreground="{DynamicResource AppTextBrush}"
                                      FontSize="18"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Bài hát tiếp theo"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextBrush}"/>

                        <Button Grid.Column="1"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="10"
                                VerticalContentAlignment="Center"
                                Foreground="{DynamicResource AppTextMutedBrush}"
                                Command="{Binding ClearWaitlistCommand}">
                            <TextBlock Text="Xóa tất cả" Margin="0 6 0 0"/>
                        </Button>
                    </Grid>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Waitlist}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="0,10,0,0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Padding="10"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding DataContext.PlayWaitlistItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding name}"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding author.name}"
                                                       Foreground="{DynamicResource AppTextMutedBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="1"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="6"
                                            Margin="0,0,6,0"
                                            Command="{Binding DataContext.RemoveWaitlistItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <fa:IconBlock Icon="Trash" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="16" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>

        <!-- ================= DETAILS (Vue-like) ================= -->
        <Border CornerRadius="0"
                Background="#D1D5DB"
                Margin="0 5 5 5"
                Visibility="{Binding IsDetailsContent, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Image Source="{Binding SongManager.CurrentTrack.thumbnail_path}"
                       Stretch="UniformToFill" />

                <!-- brightness-75 effect -->
                <Rectangle Fill="#40000000" />

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Click on the dark background to close (doesn't change the Vue look) -->
                    <Button Grid.Row="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding ClosePanelCommand}" />

                    <!-- Bottom card (Vue: absolute bottom-5, w-11/12, rounded-2xl, bg-white, p-4) -->
                    <Border Grid.Row="1"
                            Margin="16"
                            CornerRadius="12"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Giới thiệu về nghệ sĩ"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="64" Height="64" CornerRadius="32" ClipToBounds="True" Background="#9CA3AF">
                                    <Image Source="{Binding SongManager.CurrentTrack.author.avatar_path}"
                                           Stretch="UniformToFill" />
                                </Border>

                                <Button Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Padding="16,8"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource CurrentColor}"
                                        Foreground="{DynamicResource CurrentColor}"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Command="{Binding FollowOrUnfollowCurrentArtistCommand}"
                                        Visibility="{Binding IsMe, Converter={StaticResource InverseBoolToVisibility}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="999"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Content" Value="Theo dõi" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFollowed}" Value="True">
                                                    <Setter Property="Content" Value="Hủy theo dõi" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>

                            <TextBlock Text="{Binding SongManager.CurrentTrack.name}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,0,4"/>

                            <TextBlock Text="{Binding SongManager.CurrentTrack.author.followers, StringFormat={}{0} người theo dõi}"
                                       FontSize="12"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="{Binding SongManager.CurrentTrack.playlist.name, StringFormat=Album {0}}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       Margin="0,0,0,4"/>

                            <ScrollViewer MaxHeight="96" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                                <TextBlock Text="{Binding SongManager.CurrentTrack.playlist.description}"
                                           FontSize="12"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           TextWrapping="Wrap"/>
                            </ScrollViewer>

                            <TextBlock Text="Về bài hát bạn đang nghe"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       Margin="0,16,0,4"/>

                            <ScrollViewer MaxHeight="96" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                                <TextBlock Text="{Binding SongManager.CurrentTrack.description}"
                                           FontSize="12"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
