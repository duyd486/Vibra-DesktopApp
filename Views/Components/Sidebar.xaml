<UserControl x:Class="Vibra_DesktopApp.Views.Components.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="350">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- FIX: Add SidebarListItemButtonStyle resource definition -->
        <Style x:Key="SidebarListItemButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#FFE5D6"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </UserControl.Resources>

    <!-- Root layout: dark theme container -->
    <Grid Background="Transparent">
        <Border CornerRadius="10" Background="{DynamicResource WindowBackgroundBrush}" Margin="5 0 5 5" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="Auto"/> <!-- Filter -->
                    <RowDefinition Height="Auto"/> <!-- Search -->
                    <RowDefinition Height="*"/>    <!-- Lists -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="24 24 24 12" Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Thư viện"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            VerticalAlignment="Center"
                            Width="72"
                            Height="32"
                            Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding CreatePlaylistCommand}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="+" FontWeight="Bold" Margin="0,0,6,0"/>
                            <TextBlock Text="Tạo" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Filter buttons -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="16 0 16 12" HorizontalAlignment="Left">
                    <Button Content="Tất cả"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="All"
                            Width="76"
                            FontSize="12"
                            Style="{StaticResource SidebarButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Content="Danh sách phát"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="Playlist"
                            Width="120"
                            FontSize="12"
                           
                            Style="{StaticResource SidebarButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Content="Nghệ sĩ"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="Artist"
                            FontSize="12"
                            Width="72"
                            Style="{StaticResource SidebarButtonStyle}"/>
                </StackPanel>

                <!-- Search -->
                <TextBox Grid.Row="2"
                         Margin="16 0 16 12"
                         Padding="12,6"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="{DynamicResource AppTextBrush}"
                         Background="{DynamicResource ControlBackgroundBrush}"
                         BorderThickness="2"
                         BorderBrush="{Binding CurrentColor}"
                         CaretBrush="{DynamicResource AppTextBrush}"
                         FontSize="14"
                         HorizontalAlignment="Stretch">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Grid>
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Background="{TemplateBinding Background}"/>
                                            <TextBlock x:Name="Placeholder"
                                                       Text="Tìm kiếm"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontSize="14"
                                                       Margin="12,6,0,0"
                                                       IsHitTestVisible="False"
                                                       Visibility="{Binding Text.IsEmpty, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Scrollable lists -->
                <ScrollViewer Grid.Row="3" Margin="8 0 8 12" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Vertical">
                        <!-- Favorite pseudo-item (example) -->
                        <Border Padding="12" Margin="0,0,0,8" CornerRadius="8" Background="Transparent">
                            <Button Command="{Binding OpenFavoritesCommand}" Style="{StaticResource SidebarListItemButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="40" Height="40" CornerRadius="4" Background="#2A2A2A">
                                        <Image Source="{Binding FavCover}" Stretch="UniformToFill"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                        <TextBlock Text="Bài hát yêu thích" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}"/>
                                        <TextBlock Text="{Binding FavSongCount, StringFormat={}{0} bài hát}" FontSize="12" Foreground="{DynamicResource AppTextBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </Border>

                        <!-- Albums -->
                        <ItemsControl ItemsSource="{Binding MyAlbums}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12" Margin="0,0,0,8" CornerRadius="8" Background="Transparent">
                                        <Button Command="{Binding DataContext.AlbumClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SidebarListItemButtonStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="40" Height="40" CornerRadius="4">
                                                    <Image Source="{Binding thumbnail_path}" Stretch="UniformToFill"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding name}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}"/>
                                                    <TextBlock Text="Album của nghệ sĩ" FontSize="12" Foreground="{DynamicResource AppTextBrush}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="🗑"
                                                            Width="32"
                                                            Command="{Binding DeleteCommand}"
                                                            Background="Transparent"
                                                            Foreground="{DynamicResource AppTextBrush}"
                                                            BorderThickness="0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Playlists -->
                        <ItemsControl ItemsSource="{Binding MyPlaylists}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12" Margin="0,0,0,8" CornerRadius="8" Background="Transparent">
                                        <Button Command="{Binding DataContext.PlaylistClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SidebarListItemButtonStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="40" Height="40" CornerRadius="4">
                                                    <Image Source="{Binding thumbnail_path}" Stretch="UniformToFill"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding name}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}"/>
                                                    <TextBlock Text="Danh sách phát" FontSize="12" Foreground="{DynamicResource AppTextBrush}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="✏" Width="32" Command="{Binding EditCommand}" Background="Transparent" Foreground="{DynamicResource AppTextBrush}" BorderThickness="0"/>
                                                    <Button Content="🗑" Width="32" Command="{Binding DeleteCommand}" Background="Transparent" Foreground="{DynamicResource AppTextBrush}" BorderThickness="0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Artists -->
                        <ItemsControl ItemsSource="{Binding MyArtists}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12" Margin="0,0,0,8" CornerRadius="8" Background="Transparent">
                                        <Button Command="{Binding DataContext.ArtistClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding artist}"
                                                Style="{StaticResource SidebarListItemButtonStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="40" Height="40" CornerRadius="20">
                                                    <Image Source="{Binding artist.avatar_path}" Stretch="UniformToFill"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding artist.name}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}"/>
                                                    <TextBlock Text="Nghệ sĩ" FontSize="12" Foreground="{DynamicResource AppTextBrush}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="🗑" Width="32" Command="{Binding DeleteCommand}" Background="Transparent" Foreground="{DynamicResource AppTextBrush}" BorderThickness="0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
