<UserControl x:Class="Vibra_DesktopApp.Views.Components.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="350">  

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- List item button (hover highlight like Spotify) -->
        <Style x:Key="SidebarListItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#26FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search TextBox with placeholder -->
        <Style x:Key="SidebarSearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CurrentColor}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                <TextBlock x:Name="Placeholder"
                                           Text="Tìm kiếm"
                                           Foreground="#B3B3B3"
                                           Margin="12,6,0,0"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AppTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter chip button (active/inactive like Vue classes) -->
        <Style x:Key="FilterChipStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="#47342D"/>
            <Setter Property="Foreground" Value="#FFE5D6"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Border CornerRadius="0"
                Background="{DynamicResource WindowBackgroundBrush}"
                Margin="5 0 5 5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="Auto"/> <!-- Filter -->
                    <RowDefinition Height="Auto"/> <!-- Search -->
                    <RowDefinition Height="*"/>    <!-- Lists -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="20 20 20 12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Thư viện"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextBrush}"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Height="32"
                            Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding CreatePlaylistCommand}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="+" FontWeight="Bold" Margin="0,0,6,0"/>
                            <TextBlock Text="Tạo" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Filters -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20 0 20 12">
                    <Button Content="Tất cả"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="All"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterChipStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="All">
                                        <Setter Property="Background" Value="#FFE5D6"/>
                                        <Setter Property="Foreground" Value="#47342D"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Danh sách phát"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="Playlist"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterChipStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="Playlist">
                                        <Setter Property="Background" Value="#FFE5D6"/>
                                        <Setter Property="Foreground" Value="#47342D"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Nghệ sĩ"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="Artist">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterChipStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="Artist">
                                        <Setter Property="Background" Value="#FFE5D6"/>
                                        <Setter Property="Foreground" Value="#47342D"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Search -->
                <TextBox Grid.Row="2"
                         Margin="20 0 20 12"
                         Style="{StaticResource SidebarSearchTextBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Lists -->
                <ScrollViewer Grid.Row="3"
                              Margin="12 0 12 12"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource VerticalScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                    <StackPanel>

                        <!-- Fixed favorite songs playlist -->
                        <Button Style="{StaticResource SidebarListItemButtonStyle}"
                                Visibility="{Binding ShowPlaylists, Converter={StaticResource BoolToVisibility}}"
                                Command="{Binding OpenFavoriteSongsCommand}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="40" Height="40" CornerRadius="6" Background="#47342D">
                                    <TextBlock Text="❤" FontSize="16" Foreground="#FFE5D6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                    <TextBlock Text="Bài hát yêu thích" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}"/>
                                    <TextBlock Text="{Binding FavoriteSongCount, StringFormat={}{0} bài hát}" FontSize="12" Foreground="{DynamicResource AppTextMutedBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Playlists -->
                        <ItemsControl ItemsSource="{Binding PlaylistsView}"
                                      Visibility="{Binding ShowPlaylists, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SidebarListItemButtonStyle}"
                                            Command="{Binding DataContext.PlaylistClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Width="40" Height="40" CornerRadius="6">
                                                <Image Source="{Binding thumbnail_path}" Stretch="UniformToFill"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding name}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}"/>
                                                <TextBlock Text="{Binding total_song, StringFormat={}{0} bài hát}" FontSize="12" Foreground="{DynamicResource AppTextMutedBrush}"/>
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Content="🗑"
                                                    Width="32"
                                                    Height="32"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="{DynamicResource AppTextMutedBrush}"
                                                    Command="{Binding DataContext.DeletePlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Albums -->
                        <ItemsControl ItemsSource="{Binding AlbumsView}"
                                      Visibility="{Binding ShowAlbums, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SidebarListItemButtonStyle}"
                                            Command="{Binding DataContext.AlbumClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Width="40" Height="40" CornerRadius="6">
                                                <Image Source="{Binding thumbnail_path}" Stretch="UniformToFill"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding name}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}"/>
                                                <TextBlock Text="{Binding total_song, StringFormat={}{0} bài hát}" FontSize="12" Foreground="{DynamicResource AppTextMutedBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Artists -->
                        <ItemsControl ItemsSource="{Binding ArtistsView}"
                                      Visibility="{Binding ShowArtists, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SidebarListItemButtonStyle}"
                                            Command="{Binding DataContext.ArtistClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding artist}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Width="40" Height="40" CornerRadius="20">
                                                <Image Source="{Binding artist.avatar_path}" Stretch="UniformToFill"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding artist.name}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}"/>
                                                <TextBlock Text="Nghệ sĩ" FontSize="12" Foreground="{DynamicResource AppTextMutedBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
