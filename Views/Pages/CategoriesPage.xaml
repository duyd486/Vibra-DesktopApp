<UserControl x:Class="Vibra_DesktopApp.Views.Pages.CategoriesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Vibra_DesktopApp.Views.Pages"
             xmlns:behaviors="clr-namespace:Vibra_DesktopApp.Behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1250">
    <Grid Background="Transparent">
        <Border CornerRadius="0" Background="{DynamicResource WindowBackgroundBrush}" Margin="0 5 5 5">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource VerticalScrollBarStyle}"/>
                </ScrollViewer.Resources>

                <StackPanel Margin="44 24 44 24">
                    <TextBlock Text="Thể loại"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextBrush}"
                               Margin="0 0 0 14"/>

                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="320"
                                        Height="192"
                                        Margin="0 0 14 14"
                                        Cursor="Hand"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Command="{Binding DataContext.OpenCategoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Card"
                                                    CornerRadius="16"
                                                    Background="{DynamicResource ControlBackgroundBrush}"
                                                    Padding="18"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                </Border.RenderTransform>

                                                <Grid>
                                                    <TextBlock Text="{Binding name}"
                                                               Foreground="{DynamicResource AppTextBrush}"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>

                                                    <Border Width="128"
                                                            Height="128"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Bottom"
                                                            CornerRadius="14"
                                                            ClipToBounds="True"
                                                            RenderTransformOrigin="0.5,0.5">
                                                        <Border.RenderTransform>
                                                            <RotateTransform Angle="12"/>
                                                        </Border.RenderTransform>
                                                        <Grid Width="128" Height="128">
                                                            <Image Source="/Assets/Images/default.jpg" Stretch="UniformToFill" Width="128" Height="128"/>
                                                            <Image Source="{Binding thumbnail_path}" Stretch="UniformToFill" Width="128" Height="128"/>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Card" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter TargetName="Card" Property="Background" Value="{StaticResource NavActiveBackgroundBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
