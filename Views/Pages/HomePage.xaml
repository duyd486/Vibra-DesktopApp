<UserControl x:Class="Vibra_DesktopApp.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Vibra_DesktopApp.Views.Pages"
             xmlns:vm="clr-namespace:Vibra_DesktopApp.ViewModels"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:behaviors="clr-namespace:Vibra_DesktopApp.Behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1000">
    <Grid Background="Transparent">
        <Border CornerRadius="24" Background="{DynamicResource WindowBackgroundBrush}" Margin="0 5 5 5" Padding="24">
            <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource VerticalScrollBarStyle}"/>
                </ScrollViewer.Resources>

                <StackPanel>

                    <!-- Section: Bài hát phù hợp với bạn (list) -->
                    <TextBlock Text="Bài hát phù hợp với bạn"
                               FontWeight="SemiBold"
                               FontSize="24"
                               Foreground="{DynamicResource AppTextBrush}"
                               Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding ListSong}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button CommandParameter="{Binding}"
                                        Command="{Binding DataContext.PlayOrPauseThisSongCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Padding="0"
                                        HorizontalContentAlignment="Stretch">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Root" CornerRadius="10" Padding="12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="56" Height="56" CornerRadius="8" Grid.Column="0" ClipToBounds="True">
                                                        <Grid>
                                                            <Image Source="/Assets/Images/default.jpg" Stretch="UniformToFill"/>
                                                            <Image Source="{Binding thumbnail_path}" Stretch="UniformToFill"/>
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding name}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}"/>
                                                        <TextBlock Text="{Binding total_played, StringFormat={}{0} lượt nghe}" FontSize="12" Opacity="0.75" Foreground="{DynamicResource AppTextBrush}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="00:00" FontSize="12" Opacity="0.65" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                        <Button Width="32" Height="32" BorderThickness="0" Background="Transparent" Cursor="Hand"
                                                                Command="{Binding DataContext.AddToWaitlistCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}">
                                                            <fa:IconBlock Icon="List" Foreground="{DynamicResource AppTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="#0DFFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Section: Album phổ biến (carousel) -->
                    <TextBlock Text="Album phổ biến"
                               FontWeight="SemiBold"
                               FontSize="24"
                               Foreground="{DynamicResource AppTextBrush}"
                               Margin="0,28,0,12"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  behaviors:ScrollBehavior.HorizontalScrollOnly="True">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource HorizontalScrollBarStyle}"/>
                        </ScrollViewer.Resources>
                        <ItemsControl ItemsSource="{Binding ListAlbum}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="192" Margin="0,0,16,0">
                                        <Button Height="192"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.OpenAlbumDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid Width="192" Height="192">
                                                        <Border x:Name="ImageRoot" CornerRadius="16" ClipToBounds="True">
                                                            <Border.Clip>
                                                                <RectangleGeometry Rect="0,0,192,192" RadiusX="16" RadiusY="16"/>
                                                            </Border.Clip>
                                                            <Grid>
                                                                <Image Source="/Assets/Images/default.jpg" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                <Image Source="{Binding thumbnail_path}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            </Grid>
                                                        </Border>

                                                        <Border x:Name="HoverOverlay" Background="#66000000" CornerRadius="16" Opacity="0"/>

                                                        <Border x:Name="PlayBadge"
                                                                Width="56" Height="56"
                                                                CornerRadius="28"
                                                                Background="{DynamicResource CurrentColor}"
                                                                Opacity="0"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Bottom"
                                                                Margin="0,0,10,10">
                                                            <TextBlock Text="▶" FontSize="26" Foreground="#1D1512" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                                            <Setter TargetName="PlayBadge" Property="Opacity" Value="1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <TextBlock Text="{Binding name}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Margin="4,8,4,0" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding total_song, StringFormat={}{0} bài hát}" FontSize="12" Opacity="0.75" Foreground="{DynamicResource AppTextBrush}" Margin="4,2,4,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Section: Nghệ sĩ với nhiều người theo dõi (top grid + carousel) -->
                    <TextBlock Text="Nghệ sĩ với nhiều người theo dõi"
                               FontWeight="SemiBold"
                               FontSize="24"
                               Foreground="{DynamicResource AppTextBrush}"
                               Margin="0,28,0,12"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  behaviors:ScrollBehavior.HorizontalScrollOnly="True">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource HorizontalScrollBarStyle}"/>
                        </ScrollViewer.Resources>
                        <ItemsControl ItemsSource="{Binding ListArtist}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button CommandParameter="{Binding}"
                                            Command="{Binding DataContext.OpenArtistDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            Width="180" Height="300"
                                            Margin="0,0,16,0"
                                            Cursor="Hand"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid Width="180" Height="300">
                                                    <Border CornerRadius="18" ClipToBounds="True">
                                                        <Border.Clip>
                                                            <RectangleGeometry Rect="0,0,180,300" RadiusX="18" RadiusY="18"/>
                                                        </Border.Clip>
                                                        <Grid>
                                                            <Image Source="/Assets/Images/defaultUser.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            <Image Source="{Binding avatar_path}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Grid>
                                                    </Border>

                                                    <Border Background="#B0000000" Height="90" VerticalAlignment="Bottom" CornerRadius="0,0,18,18"/>

                                                    <StackPanel VerticalAlignment="Bottom" Margin="14,0,14,14">
                                                        <TextBlock Text="{Binding name}" Foreground="White" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding followers, StringFormat={}{0} người theo dõi}" Foreground="#CCFFFFFF" FontSize="12"/>
                                                    </StackPanel>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Section: Bài hát có nhiều lượt nghe (carousel + list) -->
                    <TextBlock Text="Bài hát có nhiều lượt nghe"
                               FontWeight="SemiBold"
                               FontSize="24"
                               Foreground="{DynamicResource AppTextBrush}"
                               Margin="0,12,0,12"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  behaviors:ScrollBehavior.HorizontalScrollOnly="True">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource HorizontalScrollBarStyle}"/>
                        </ScrollViewer.Resources>
                        <ItemsControl ItemsSource="{Binding ListSong}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="200" Margin="0,0,16,0">
                                        <Button Width="180" Height="180"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.PlayOrPauseThisSongCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid Width="180" Height="180">
                                                        <Ellipse>
                                                            <Ellipse.Fill>
                                                                <ImageBrush ImageSource="{Binding thumbnail_path}" Stretch="UniformToFill"/>
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                        <Border x:Name="SongPlayBadge"
                                                                Width="56" Height="56"
                                                                CornerRadius="28"
                                                                Background="{DynamicResource CurrentColor}"
                                                                Opacity="0"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Bottom"
                                                                Margin="0,0,10,10">
                                                            <TextBlock Text="▶" FontSize="26" Foreground="#1D1512" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="SongPlayBadge" Property="Opacity" Value="1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <Grid Margin="4,8,4,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding name}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding total_played, StringFormat={}{0} lượt nghe}" FontSize="12" Opacity="0.75" Foreground="{DynamicResource AppTextBrush}"/>
                                            </StackPanel>
                                            <Button Width="32" Height="32" Grid.Column="1" BorderThickness="0" Background="Transparent" Cursor="Hand"
                                                    Command="{Binding DataContext.AddToWaitlistCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <fa:IconBlock Icon="List" Foreground="{DynamicResource AppTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
