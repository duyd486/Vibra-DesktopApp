<UserControl x:Class="Vibra_DesktopApp.Views.Pages.ArtistPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="1250">

    <Grid Background="Transparent">
        <Border CornerRadius="0"
                Background="{DynamicResource WindowBackgroundBrush}"
                Margin="0 5 5 5">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource VerticalScrollBarStyle}"/>
                </ScrollViewer.Resources>
                <StackPanel>

                    <!-- HERO -->
                    <Grid Height="320">
                        <Image Source="{Binding Artist.avatar_path}" Stretch="UniformToFill"/>
                        <Border Background="#80000000"/>

                        <StackPanel VerticalAlignment="Bottom" Margin="44 0 44 28">
                            <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                                <fa:IconBlock Icon="CheckCircle" Foreground="#3EA6FF" FontSize="18" Margin="0 0 8 0"/>
                                <TextBlock Text="Nghệ sĩ được xác minh"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="16"/>
                            </StackPanel>

                            <TextBlock Text="{Binding Artist.name}"
                                       Foreground="White"
                                       FontWeight="Black"
                                       FontSize="64"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="{Binding Artist.followers, StringFormat={}{0} người theo dõi}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="16"
                                       Margin="0 6 0 0"/>
                        </StackPanel>
                    </Grid>

                    <!-- ACTIONS -->
                    <Grid Margin="44 18 44 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- PLAY -->
                            <Button Width="56" Height="56"
                                    Background="{DynamicResource CurrentColor}"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Command="{Binding PlaySongCommand}"
                                    CommandParameter="{Binding ArtistSongs[0]}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="28" Background="{TemplateBinding Background}">
                                            <fa:IconBlock Icon="Play" Foreground="#1D1512" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- FOLLOW / UNFOLLOW -->
                            <Button Margin="18 0 0 0"
                                    Padding="16,8"
                                    Background="Transparent"
                                    BorderThickness="1.5"
                                    BorderBrush="{DynamicResource CurrentColor}"
                                    Foreground="{DynamicResource CurrentColor}"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Command="{Binding FollowOrUnfollowCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Content" Value="Theo dõi"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMe}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsFollowed}" Value="True">
                                                <Setter Property="Content" Value="Hủy theo dõi"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- BLOCK -->
                        <Button Grid.Column="1"
                                Padding="16,8"
                                Background="Transparent"
                                BorderThickness="1.5"
                                BorderBrush="#E53935"
                                Foreground="#E53935"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Command="{Binding BlockArtistCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Content" Value="Hạn chế nghệ sĩ"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMe}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- POPULAR SONGS -->
                    <StackPanel Margin="44 22 44 0">
                        <TextBlock Text="Phổ biến"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   Margin="0 0 0 10"/>

                        <ItemsControl ItemsSource="{Binding ArtistSongs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10"
                                            Background="Transparent"
                                            Padding="10"
                                            Margin="0 0 0 6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#141414"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding name}"
                                                           Foreground="{DynamicResource AppTextBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="16"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding author.name}"
                                                           Foreground="{DynamicResource AppTextMutedBrush}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="6"
                                                        Command="{Binding DataContext.AddToWaitlistCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <fa:IconBlock Icon="List" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="16" />
                                                </Button>
                                            </StackPanel>

                                            <Border Grid.ColumnSpan="2" Background="Transparent">
                                                <Border.InputBindings>
                                                    <MouseBinding Gesture="LeftClick"
                                                                 Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                 CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ABOUT -->
                    <StackPanel Margin="44 26 44 0">
                        <TextBlock Text="Giới thiệu về nghệ sĩ"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   Margin="0 0 0 10"/>

                        <Grid Height="320">
                            <Image Source="{Binding Artist.avatar_path}" Stretch="UniformToFill"/>
                            <Border Background="#80000000" CornerRadius="18"/>
                            <Border CornerRadius="18" Background="Transparent" Padding="22">
                                <StackPanel VerticalAlignment="Bottom">
                                    <TextBlock Foreground="White"
                                               FontWeight="SemiBold"
                                               FontSize="18"
                                               Text="{Binding Artist.followers, StringFormat={}{0} người theo dõi trên nền tảng}"/>
                                    <TextBlock Foreground="White"
                                               FontSize="16"
                                               TextWrapping="Wrap"
                                               Margin="0 8 0 0"
                                               Text="{Binding Artist.description}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- ALBUMS -->
                    <StackPanel Margin="44 26 44 24">
                        <TextBlock Text="Danh sách Album"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   Margin="0 0 0 10"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ArtistAlbums}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="180" Margin="0 0 14 0">
                                            <Border Width="180" Height="180" CornerRadius="14" Background="#333" ClipToBounds="True">
                                                <Image Source="{Binding thumbnail_path}" Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock Text="{Binding name}"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="16"
                                                       Margin="0 8 0 0"/>
                                            <TextBlock Text="{Binding created_at, StringFormat={}{0:yyyy}}"
                                                       Foreground="#AAA"
                                                       FontSize="13"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
