<UserControl x:Class="Vibra_DesktopApp.Views.Pages.CategorySongsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:behaviors="clr-namespace:Vibra_DesktopApp.Behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1250">

    <Grid Background="Transparent">
        <Border CornerRadius="0" Background="{DynamicResource WindowBackgroundBrush}" Margin="0 5 5 5">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource VerticalScrollBarStyle}"/>
                </ScrollViewer.Resources>

                <StackPanel Margin="44 24 44 24">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 0 12">
                        <Button Width="40" Height="40"
                                Background="{DynamicResource ControlBackgroundBrush}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding BackCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="20" Background="{TemplateBinding Background}">
                                        <fa:IconBlock Icon="ArrowLeft" Foreground="{DynamicResource AppTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Margin="12 0 0 0"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextBrush}">
                            <Run Text="Danh sách nhạc "/>
                            <Run Text="{Binding Category.name}"/>
                            <Run Text=" nổi bật"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- TOP SONGS (max 4) -->
                    <ItemsControl ItemsSource="{Binding TopSongs}" Margin="0 0 0 20">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="236" Margin="0 0 18 18">
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Padding="0"
                                            Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Root" RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                    <Border Width="192" Height="192" CornerRadius="96" ClipToBounds="True" Background="#333" HorizontalAlignment="Center">
                                                        <Grid Width="192" Height="192">
                                                            <Image Source="/Assets/Images/default.jpg" Stretch="UniformToFill" Width="192" Height="192"/>
                                                            <Image Source="{Binding thumbnail_path}" Stretch="UniformToFill" Width="192" Height="192"/>
                                                        </Grid>
                                                    </Border>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Root" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <StackPanel Margin="0 12 0 0" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding name}" 
                                                   Foreground="{DynamicResource AppTextBrush}" 
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 6 0 0">
                                            <TextBlock Text="{Binding total_played, StringFormat={}{0} lượt nghe}"
                                                       Foreground="{DynamicResource AppTextMutedBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>

                                            <Button Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="6"
                                                    Margin="6 0 0 0"
                                                    Command="{Binding DataContext.AddToWaitlistCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <fa:IconBlock Icon="List" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="16" />
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Bài hát"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextBrush}"
                               Margin="0 0 0 10"/>

                    <!-- SONG LIST -->
                    <ScrollViewer Height="360" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource VerticalScrollBarStyle}"/>
                        </ScrollViewer.Resources>

                        <ItemsControl ItemsSource="{Binding Songs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10"
                                            Background="Transparent"
                                            Padding="10"
                                            Margin="0 0 0 6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#141414"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Width="44" Height="44" CornerRadius="10" ClipToBounds="True" Background="#333">
                                                <Grid Width="44" Height="44">
                                                    <Image Source="/Assets/Images/default.jpg" Stretch="UniformToFill" Width="44" Height="44"/>
                                                    <Image Source="{Binding thumbnail_path}" Stretch="UniformToFill" Width="44" Height="44"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="12 0 0 0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding name}"
                                                           Foreground="{DynamicResource AppTextBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="15"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding author.name}"
                                                           Foreground="{DynamicResource AppTextMutedBrush}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding total_played, StringFormat={}{0} lượt nghe}"
                                                           Foreground="{DynamicResource AppTextMutedBrush}"
                                                           FontSize="12"
                                                           Margin="0 0 10 0"
                                                           VerticalAlignment="Center"/>

                                                <Button Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="6"
                                                        Command="{Binding DataContext.AddToWaitlistCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <fa:IconBlock Icon="List" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="16"/>
                                                </Button>
                                            </StackPanel>

                                            <Border Grid.ColumnSpan="3" Background="Transparent">
                                                <Border.InputBindings>
                                                    <MouseBinding Gesture="LeftClick"
                                                                 Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                 CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
