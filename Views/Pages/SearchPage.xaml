<UserControl x:Class="Vibra_DesktopApp.Views.Pages.SearchPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Vibra_DesktopApp.Views.Pages"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:behaviors="clr-namespace:Vibra_DesktopApp.Behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1250">
    <Grid Background="Transparent">
        <Border CornerRadius="0" Background="{DynamicResource WindowBackgroundBrush}" Margin="0 5 5 5">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource VerticalScrollBarStyle}"/>
                </ScrollViewer.Resources>

                <StackPanel>
                    <!-- TOP SEARCH + SONG LIST -->
                    <Grid Margin="44 24 44 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="1.7*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Top search card -->
                        <StackPanel Grid.Column="0" Margin="0 0 22 0">
                            <TextBlock Text="Top tìm kiếm"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       Margin="0 0 0 10"/>

                            <Button Command="{Binding PlayTopSongCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Card"
                                                CornerRadius="16"
                                                Background="{DynamicResource ControlBackgroundBrush}"
                                                Padding="16">
                                            <Grid>
                                                <StackPanel>
                                                    <Border Width="110" Height="110" CornerRadius="12" ClipToBounds="True" Background="#333">
                                                        <Grid Width="110" Height="110">
                                                            <Image Source="/Assets/Images/default.jpg" Stretch="UniformToFill" Width="110" Height="110"/>
                                                            <Image Source="{Binding TopSong.thumbnail_path}" Stretch="UniformToFill" Width="110" Height="110"/>
                                                        </Grid>
                                                    </Border>

                                                    <TextBlock Text="{Binding TopSong.name, TargetNullValue=Không có bài hát}"
                                                               Foreground="{DynamicResource AppTextBrush}"
                                                               FontSize="24"
                                                               FontWeight="Bold"
                                                               Margin="0 12 0 2"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <TextBlock Foreground="{DynamicResource AppTextMutedBrush}" FontSize="13">
                                                        <Run Text="Bài hát • "/>
                                                        <Run Text="{Binding TopSong.author.name}" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <Border x:Name="PlayBtn"
                                                        Width="56" Height="56"
                                                        CornerRadius="28"
                                                        Background="{DynamicResource CurrentColor}"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Bottom"
                                                        Opacity="0">
                                                    <fa:IconBlock Icon="Play" Foreground="#1D1512" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Card" Property="Background" Value="{StaticResource NavActiveBackgroundBrush}"/>
                                                <Setter TargetName="PlayBtn" Property="Opacity" Value="1"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding TopSong}" Value="{x:Null}">
                                                <Setter TargetName="PlayBtn" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- Song list -->
                        <StackPanel Grid.Column="1">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Songs.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="Bài hát"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       Margin="0 0 0 10"/>

                            <ScrollViewer Height="240" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource VerticalScrollBarStyle}"/>
                                </ScrollViewer.Resources>

                                <ItemsControl ItemsSource="{Binding Songs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10"
                                                    Background="Transparent"
                                                    Padding="10"
                                                    Margin="0 0 0 6">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#141414"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="44" Height="44" CornerRadius="10" ClipToBounds="True" Background="#333">
                                                        <Grid Width="44" Height="44">
                                                            <Image Source="/Assets/Images/default.jpg" Stretch="UniformToFill" Width="44" Height="44"/>
                                                            <Image Source="{Binding thumbnail_path}" Stretch="UniformToFill" Width="44" Height="44"/>
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Margin="12 0 0 0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding name}"
                                                                   Foreground="{DynamicResource AppTextBrush}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="15"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding author.name}"
                                                                   Foreground="{DynamicResource AppTextMutedBrush}"
                                                                   FontSize="12"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding total_played, StringFormat={}{0} lượt nghe}"
                                                                   Foreground="{DynamicResource AppTextMutedBrush}"
                                                                   FontSize="12"
                                                                   Margin="0 0 10 0"
                                                                   VerticalAlignment="Center"/>

                                                        <Button Background="Transparent"
                                                                BorderThickness="0"
                                                                Padding="6"
                                                                Command="{Binding DataContext.AddToWaitlistCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}">
                                                            <fa:IconBlock Icon="List" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="16"/>
                                                        </Button>
                                                    </StackPanel>

                                                    <Border Grid.ColumnSpan="3" Background="Transparent">
                                                        <Border.InputBindings>
                                                            <MouseBinding Gesture="LeftClick"
                                                                         Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                         CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Grid>

                    <!-- ARTISTS -->
                    <StackPanel Margin="44 26 44 0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Artists.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="Nghệ sĩ"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   Margin="0 0 0 10"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      behaviors:ScrollBehavior.HorizontalScrollOnly="True">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource HorizontalScrollBarStyle}"/>
                            </ScrollViewer.Resources>

                            <ItemsControl ItemsSource="{Binding Artists}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Width="190"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Padding="0"
                                                Margin="0 0 14 0"
                                                Command="{Binding DataContext.OpenArtistDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Root" Background="Transparent" RenderTransformOrigin="0.5,0.5">
                                                        <Border.RenderTransform>
                                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                        </Border.RenderTransform>
                                                        <StackPanel>
                                                            <Border Width="180" Height="180" CornerRadius="90" ClipToBounds="True" Background="#333">
                                                                <Grid Width="180" Height="180">
                                                                    <Image Source="/Assets/Images/defaultUser.png" Stretch="UniformToFill" Width="180" Height="180"/>
                                                                    <Image Source="{Binding avatar_path}" Stretch="UniformToFill" Width="180" Height="180"/>
                                                                </Grid>
                                                            </Border>

                                                            <TextBlock Text="{Binding name}"
                                                                       Foreground="{DynamicResource AppTextBrush}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="15"
                                                                       Margin="0 10 0 2"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding followers, StringFormat={}{0} người theo dõi}"
                                                                       Foreground="{DynamicResource AppTextMutedBrush}"
                                                                       FontSize="12"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Root" Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- ALBUMS -->
                    <StackPanel Margin="44 26 44 24">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Albums.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="Albums"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   Margin="0 0 0 10"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      behaviors:ScrollBehavior.HorizontalScrollOnly="True">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource HorizontalScrollBarStyle}"/>
                            </ScrollViewer.Resources>

                            <ItemsControl ItemsSource="{Binding Albums}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="180" Margin="0 0 14 0">
                                            <Button Width="180" Height="180"
                                                    Cursor="Hand"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Command="{Binding DataContext.OpenAlbumDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Root" Width="180" Height="180" CornerRadius="14" ClipToBounds="True" RenderTransformOrigin="0.5,0.5">
                                                            <Border.RenderTransform>
                                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                            </Border.RenderTransform>
                                                            <Grid Width="180" Height="180">
                                                                <Image Source="/Assets/Images/default.jpg" Stretch="UniformToFill" Width="180" Height="180"/>
                                                                <Image Source="{Binding thumbnail_path}" Stretch="UniformToFill" Width="180" Height="180"/>

                                                                <Border x:Name="Overlay" Background="#66000000" Opacity="0"/>
                                                                <Border x:Name="CenterIcon"
                                                                        Width="48" Height="48"
                                                                        CornerRadius="32"
                                                                        Background="{DynamicResource CurrentColor}"
                                                                        Opacity="0"
                                                                        Margin="0 0 10 10"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Bottom">
                                                                    <fa:IconBlock Icon="Play" Foreground="#1D1512" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </Grid>
                                                        </Border>

                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Overlay" Property="Opacity" Value="1"/>
                                                                <Setter TargetName="CenterIcon" Property="Opacity" Value="1"/>
                                                                <Setter TargetName="Root" Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <TextBlock Text="{Binding name}"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="15"
                                                       Margin="0 10 0 2"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding description}"
                                                       Foreground="{DynamicResource AppTextMutedBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

